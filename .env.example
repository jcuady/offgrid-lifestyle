# Supabase — required for database, auth, and real-time features
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# VAPID keys for Web Push notifications (generate with: npx web-push generate-vapid-keys)
VITE_VAPID_PUBLIC_KEY="your-vapid-public-key"

# Set these as Supabase Edge Function secrets for send-push:
# VAPID_PUBLIC_KEY, VAPID_PRIVATE_KEY, VAPID_EMAIL (e.g. push@offgrid.ph)

# PayMongo (optional)
# VITE_PAYMONGO_PUBLIC_KEY="pk_test_..."
