# Supabase — required for database, auth, and real-time features
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# VAPID keys for Web Push notifications (generate with: npx web-push generate-vapid-keys)
# Public key also goes in Vercel as VITE_VAPID_PUBLIC_KEY (must match edge VAPID_PUBLIC_KEY)
VITE_VAPID_PUBLIC_KEY="your-vapid-public-key"

# Google Analytics 4 — optional (set in Vercel Production env)
VITE_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# Google Search Console — HTML tag verification (optional; DNS TXT also works)
VITE_GSC_VERIFICATION="your-google-site-verification-token"

# Set these as Supabase Edge Function secrets for send-push:
# VAPID_PUBLIC_KEY, VAPID_PRIVATE_KEY, VAPID_EMAIL (e.g. push@offgrid.ph)

# Playwright E2E — signup/sign-in flows (never commit real passwords)
# E2E_SIGNUP_EMAIL="you@example.com"
# E2E_SIGNUP_PASSWORD="use-a-dedicated-test-password"
# E2E_SIGNUP_NAME="E2E Test User"
# E2E_SIGNUP_PHONE="+63 917 000 0001"
# SUPABASE_SERVICE_ROLE_KEY="..."  # optional; confirms/unconfirms test email in admin helpers

# PayMongo — public key only in Vite (optional; also stored in og_payment_settings)
# VITE_PAYMONGO_PUBLIC_KEY="pk_test_..."
# Secret key + webhook secret are Supabase Edge secrets / Vault only — never VITE_*:
# PAYMONGO_SECRET_KEY="sk_test_..."
# PAYMONGO_WEBHOOK_SECRET="whsec_..."
# SITE_URL="https://www.oglifestyleph.com"

# Resend — set as Supabase Edge Function secrets (never commit API keys):
# RESEND_API_KEY="re_..."
# RESEND_FROM_EMAIL="OFF GRID Lifestyle <hello@oglifestyleph.com>"
# CONTACT_INBOX_EMAIL="offxgrid2024@gmail.com"
# SITE_URL="https://www.oglifestyleph.com"
# ALLOWED_ORIGINS="https://www.oglifestyleph.com,https://oglifestyleph.com"
# SEND_EMAIL_HOOK_SECRET="v1,whsec_..."  # from Supabase Auth → Hooks → Send Email
